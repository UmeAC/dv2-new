{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "url": "https://raw.githubusercontent.com/UmeAC/dv2-new/refs/heads/main/data/reason_trips%20update.csv",
    "format": {
      "type": "csv",
      "parse": {"year": "number", "trips": "number"}
    }
  },
  "params": [
    {
      "name": "reason_select",
      "value": "Holiday",
      "bind": {
        "name": "Reason: ",
        "input": "select",
        "options": ["Holiday", "Visiting Friends & Relatives", "Business", "Other"]
      }
    },
    {
      "name": "type_select",
      "value": "Total",
      "bind": {
        "name": "Trip Type: ",
        "input": "select",
        "options": ["Total", "Interstate", "Intrastate"]
      }
    }
  ],
  "transform": [
    { "filter": "datum.year >= 2021 && datum.year <= 2024" },
    { "filter": "datum.reason === reason_select" },
    { "filter": "type_select === 'Total' || datum.trip_type === type_select" },
    {
      "aggregate": [{"op": "sum", "field": "trips", "as": "total_trips"}],
      "groupby": ["state", "year", "reason"]
    },
    {
      "calculate": "datum.year <= 2022 ? 'pair_2122' : 'pair_2324'",
      "as": "year_pair"
    },
    {
      "calculate": "datum.state + '_' + datum.year_pair",
      "as": "line_group"
    }
  ],
  "width": "container",
  "height": 450,
  "layer": [
    {
      "mark": {
        "type": "line",
        "strokeWidth": 2.5,
        "strokeCap": "round"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "title": null,
          "axis": {
            "labelFontSize": 13,
            "labelFontWeight": "bold",
            "orient": "top",
            "domain": false,
            "ticks": false
          }
        },
        "y": {
          "field": "total_trips",
          "type": "quantitative",
          "title": "Trips ('000)",
          "axis": {"format": ",.0f", "grid": true}
        },
        "color": {
          "field": "state",
          "type": "nominal",
          "title": "State",
          "scale": {
            "domain": ["NSW", "VIC", "QLD", "WA", "SA", "TAS", "NT", "ACT"],
            "range": ["#0072B2", "#E69F00", "#009E73", "#858C74", "#CC79A7", "#56B4E9", "#F0E442", "#333333"]
          }
        },
        "detail": {"field": "line_group"},
        "strokeDash": {
          "field": "year_pair",
          "type": "nominal",
          "scale": {
            "domain": ["pair_2122", "pair_2324"],
            "range": [[4, 3], [1, 0]]
          },
          "legend": {
            "title": "Period",
            "labelExpr": "datum.label === 'pair_2122' ? '2021–2022' : '2023–2024'"
          }
        },
        "opacity": {
          "condition": {
            "test": {"or": [
              {"param": "state_hover", "empty": false},
              {"param": "state_click", "empty": false}
            ]},
            "value": 4
          },
          "value": 1.5
        },
        "strokeWidth": {
          "condition": {
            "test": {"or": [
              {"param": "state_hover", "empty": false},
              {"param": "state_click", "empty": false}
            ]},
            "value": 4
          },
          "value": 1.5
        }
      }
    },
    {
      "params": [
        {
          "name": "state_hover",
          "select": {
            "type": "point",
            "fields": ["state"],
            "toggle": false,
            "on": "pointerover"
          }
        },
        {
          "name": "state_click",
          "select": {"type": "point", "fields": ["state"]}
        }
      ],
      "mark": {"type": "circle", "size": 100},
      "encoding": {
        "x": {"field": "year", "type": "ordinal"},
        "y": {"field": "total_trips", "type": "quantitative"},
        "color": {"field": "state", "type": "nominal"},
        "opacity": {
          "condition": {
            "test": {"or": [
              {"param": "state_hover", "empty": false},
              {"param": "state_click", "empty": false}
            ]},
            "value": 4
          },
          "value": 1.5
        },
        "tooltip": [
          {"field": "state", "type": "nominal", "title": "State"},
          {"field": "year", "type": "ordinal", "title": "Year"},
          {"field": "total_trips", "type": "quantitative", "title": "Trips ('000)", "format": ",.1f"}
        ]
      }
    },
    {
      "transform": [
        {"filter": "datum.year === 2021"},
        {
          "filter": {
            "or": [
              {"param": "state_hover", "empty": false},
              {"param": "state_click", "empty": false}
            ]
          }
        }
      ],
      "mark": {"type": "text", "align": "right", "dx": -12, "fontSize": 12, "fontWeight": "bold"},
      "encoding": {
        "x": {"field": "year", "type": "ordinal"},
        "y": {"field": "total_trips", "type": "quantitative"},
        "text": {"field": "total_trips", "type": "quantitative", "format": ",.0f"},
        "color": {"field": "state", "type": "nominal"}
      }
    },
    {
      "transform": [
        {"filter": "datum.year === 2022"},
        {
          "filter": {
            "or": [
              {"param": "state_hover", "empty": false},
              {"param": "state_click", "empty": false}
            ]
          }
        }
      ],
      "mark": {"type": "text", "align": "left", "dx": 12, "fontSize": 12, "fontWeight": "bold"},
      "encoding": {
        "x": {"field": "year", "type": "ordinal"},
        "y": {"field": "total_trips", "type": "quantitative"},
        "text": {"field": "total_trips", "type": "quantitative", "format": ",.0f"},
        "color": {"field": "state", "type": "nominal"}
      }
    },
    {
      "transform": [
        {"filter": "datum.year === 2023"},
        {
          "filter": {
            "or": [
              {"param": "state_hover", "empty": false},
              {"param": "state_click", "empty": false}
            ]
          }
        }
      ],
      "mark": {"type": "text", "align": "right", "dx": -12, "fontSize": 12, "fontWeight": "bold"},
      "encoding": {
        "x": {"field": "year", "type": "ordinal"},
        "y": {"field": "total_trips", "type": "quantitative"},
        "text": {"field": "total_trips", "type": "quantitative", "format": ",.0f"},
        "color": {"field": "state", "type": "nominal"}
      }
    },
    {
      "transform": [
        {"filter": "datum.year === 2024"},
        {
          "filter": {
            "or": [
              {"param": "state_hover", "empty": false},
              {"param": "state_click", "empty": false}
            ]
          }
        }
      ],
      "mark": {"type": "text", "align": "left", "dx": 12, "fontSize": 12, "fontWeight": "bold"},
      "encoding": {
        "x": {"field": "year", "type": "ordinal"},
        "y": {"field": "total_trips", "type": "quantitative"},
        "text": {"field": "total_trips", "type": "quantitative", "format": ",.0f"},
        "color": {"field": "state", "type": "nominal"}
      }
    },
    {
      "transform": [
        {"filter": "datum.year === 2024"},
        {
          "filter": {
            "or": [
              {"param": "state_hover", "empty": false},
              {"param": "state_click", "empty": false}
            ]
          }
        }
      ],
      "mark": {"type": "text", "align": "left", "dx": 65, "fontSize": 12, "fontWeight": "bold"},
      "encoding": {
        "x": {"field": "year", "type": "ordinal"},
        "y": {"field": "total_trips", "type": "quantitative"},
        "text": {"field": "state", "type": "nominal"},
        "color": {"field": "state", "type": "nominal"}
      }
    }
  ],
  "config": {
    "view": {"stroke": null},
    "axis": {"labelFontSize": 11}
  }
}