{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "height": 500,
  "width": "container",
  "data": {
    "url": "https://raw.githubusercontent.com/UmeAC/DV2/refs/heads/main/data/domestic%20dec2024dec2025.csv",
    "format": {"type": "csv"}
  },
  "projection": {"type": "mercator"},
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/UmeAC/DV2/refs/heads/main/js/ne_1-3.json",
        "format": {"type": "topojson", "feature": "ne_10m_admin_1_states_provinces"}
      },
      "transform": [
        {
          "lookup": "properties.name",
          "from": {
            "data": {
              "url": "https://raw.githubusercontent.com/UmeAC/DV2/refs/heads/main/data/domestic%20dec2024dec2025.csv"
            },
            "key": "name",
            "fields": ["Expenditure", "E_change", "night", "Expenditure_2024"]
          }
        }
      ],
      "mark": {"type": "geoshape", "stroke": "white"},
      "encoding": {
        "color": {
          "field": "Expenditure",
          "type": "quantitative",
          "title": "Expenditure ($M)",
          "scale": {"scheme": "purples"},
          "legend": {
            "orient": "bottom",
            "direction": "horizontal",
            "gradientLength": 220
          }
        },
        "tooltip": [
          {"field": "properties.name", "type": "nominal", "title": "name"},
          {"field": "Expenditure", "type": "quantitative", "title": "Expenditure 2025 ($M)"},
          {"field": "Expenditure_2024", "type": "quantitative", "title": "Expenditure 2024 ($M)"},
          {"field": "E_change", "type": "quantitative", "title": "% Change"}
        ]
      }
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/UmeAC/DV2/refs/heads/main/data/domestic%20dec2024dec2025.csv"
      },
      "mark": {"type": "text", "fontSize": 11, "fontWeight": "bold", "dy": -8},
      "encoding": {
        "longitude": {"field": "long", "type": "quantitative"},
        "latitude": {"field": "lat", "type": "quantitative"},
        "text": {"field": "name", "type": "nominal"},
        "color": {
          "condition": {
            "test": "indexof(['Queensland', 'New South Wales', 'Victoria'], datum.name) >= 0",
            "value": "white"
          },
          "value": "black"
        },
        "opacity": {
          "condition": {
            "test": "indexof(['Jervis Bay Territory', 'Australian Capital Territory'], datum.name) >= 0",
            "value": 0
          },
          "value": 1
        }
      }
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/UmeAC/DV2/refs/heads/main/data/domestic%20dec2024dec2025.csv"
      },
      "transform": [
        {"filter": "indexof(['Jervis Bay Territory', 'Australian Capital Territory'], datum.name) < 0"},
        {"calculate": "datum.E_change > 0 ? '+' + datum.E_change + '%' : datum.E_change + '%'", "as": "change_label"}
      ],
      "mark": {"type": "text", "fontSize": 14, "fontWeight": "normal", "dy": 8},
      "encoding": {
        "longitude": {"field": "long", "type": "quantitative"},
        "latitude": {"field": "lat", "type": "quantitative"},
        "text": {"field": "change_label", "type": "nominal"},
        "color": {
          "condition": {
            "test": "indexof(['Queensland', 'New South Wales', 'Victoria'], datum.name) >= 0",
            "value": "rgba(255,255,255,0.85)"
          },
          "value": "rgba(0,0,0,0.65)"
        }
      }
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/UmeAC/DV2/refs/heads/main/data/domestic%20dec2024dec2025.csv"
      },
      "transform": [
        {"filter": "datum.name == 'Australian Capital Territory'"}
      ],
      "mark": {
        "type": "text",
        "fontSize": 11,
        "fontWeight": "bold",
        "color": "black",
        "align": "left",
        "dx": 25,
        "dy": -8
      },
      "encoding": {
        "longitude": {"field": "long", "type": "quantitative"},
        "latitude": {"field": "lat", "type": "quantitative"},
        "text": {"field": "name", "type": "nominal"}
      }
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/UmeAC/DV2/refs/heads/main/data/domestic%20dec2024dec2025.csv"
      },
      "transform": [
        {"filter": "datum.name == 'Australian Capital Territory'"},
        {"calculate": "datum.E_change > 0 ? '+' + datum.E_change + '%' : datum.E_change + '%'", "as": "change_label"}
      ],
      "mark": {
        "type": "text",
        "fontSize": 14,
        "fontWeight": "normal",
        "color": "rgba(0,0,0,0.65)",
        "align": "left",
        "dx": 19,
        "dy": 8
      },
      "encoding": {
        "longitude": {"field": "long", "type": "quantitative"},
        "latitude": {"field": "lat", "type": "quantitative"},
        "text": {"field": "change_label", "type": "nominal"}
      }
    }
  ]
}