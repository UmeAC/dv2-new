{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "url": "https://raw.githubusercontent.com/UmeAC/dv2-new/refs/heads/main/Australia_tourism/data/international_overview.csv",
    "format": { "type": "csv", "parse": { "year": "number", "inbound_arrivals": "number", "outbound_returns": "number", "intl_spend_real": "number" } }
  },
  "vconcat": [
    {
      "width": 700, "height": 260,
      "title": { "text": "Inbound vs Outbound Travellers ('000) — drag to select a period", "fontSize": 12, "color": "#555" },
      "transform": [
        { "fold": ["inbound_arrivals", "outbound_returns"], "as": ["metric_type", "travellers"] },
        { "calculate": "datum.metric_type === 'inbound_arrivals' ? 'Inbound' : 'Outbound'", "as": "Series" }
      ],
      "layer": [
        {
          "description": "Forecast background region shading",
          "mark": { "type": "rect", "opacity": 0.05, "color": "#4863a0" },
          "transform": [{ "filter": "datum.type === 'forecast'" }],
          "encoding": {
            "x": { "field": "year", "type": "quantitative" },
            "x2": { "value": 700 }, "y": { "value": 0 }, "y2": { "value": 260 }
          }
        },
        {
          "description": "Forecast marker threshold line",
          "mark": { "type": "rule", "strokeDash": [4,3], "color": "#ccc" },
          "transform": [{ "filter": "datum.year === 2024" }],
          "encoding": { "x": { "field": "year", "type": "quantitative" } }
        },
        {
          "description": "Historical actual data line trend",
          "mark": { "type": "line", "strokeWidth": 2.5, "interpolate": "monotone" },
          "transform": [{ "filter": "datum.type === 'actual'" }],
          "encoding": {
            "x": { "field": "year", "type": "quantitative", "scale": { "zero": false }, "axis": { "format": "d", "title": null } },
            "y": { "field": "travellers", "type": "quantitative", "axis": { "title": "Travellers ('000)", "format": ",.0f" } },
            "color": {
              "field": "Series", "type": "nominal",
              "scale": {
                "domain": ["Inbound", "Outbound"],
                "range": ["#005ab5", "#dc7d28"]
              }
            }
          }
        },
        {
          "description": "Dashed forecast line trend",
          "mark": { "type": "line", "strokeWidth": 2.5, "strokeDash": [6,4], "interpolate": "monotone" },
          "transform": [{ "filter": "datum.type === 'forecast' || datum.year === 2024" }],
          "encoding": {
            "x": { "field": "year", "type": "quantitative" },
            "y": { "field": "travellers", "type": "quantitative" },
            "color": { "field": "Series", "type": "nominal" }
          }
        },
        {
          "description": "Pandemic milestone outlier highlight node",
          "mark": { "type": "point", "filled": true, "size": 130, "color": "#e64040", "opacity": 1},
          "transform": [{ "filter": "datum.year === 2021 && datum.Series === 'Inbound'" }],
          "encoding": {
            "x": { "field": "year", "type": "quantitative" },
            "y": { "field": "travellers", "type": "quantitative" }
          }
        },
        {
          "description": "Pandemic highlight commentary text",
          "mark": { "type": "text", "align": "right", "dx": -30, "dy": -9, "fontSize": 9.5, "fontWeight": "bold", "color": "#e64040" },
          "transform": [{ "filter": "datum.year === 2021 && datum.Series === 'Inbound'" }],
          "encoding": {
            "x": { "field": "year", "type": "quantitative" },
            "y": { "field": "travellers", "type": "quantitative" },
            "text": { "value": "Pandemic trough" }
          }
        },
        {
          "description": "Interactive data nodes for tracking tooltips and driving brush bounds",
          "params": [{ "name": "brush", "select": { "type": "interval", "encodings": ["x"] } }],
          "mark": { "type": "circle", "size": 65 },
          "encoding": {
            "x": { "field": "year", "type": "quantitative" },
            "y": { "field": "travellers", "type": "quantitative" },
            "color": { "field": "Series", "type": "nominal" },
            "opacity": { "value": 0.4 },
            "tooltip": [
              { "field": "year", "type": "quantitative", "title": "Year", "format": "d" },
              { "field": "Series", "type": "nominal", "title": "Metric" },
              { "field": "travellers", "type": "quantitative", "title": "Count ('000)", "format": ",.0f" },
              { "field": "type", "type": "nominal", "title": "Period Context" },
              { "field": "intl_spend_real", "type": "quantitative", "title": "Total Spend ($B Real)", "format": ".2f" }
            ]
          }
        },
        {
          "description": "Inline text labeling for Inbound trend line",
          "mark": { "type": "text", "align": "left", "dx": 15, "dy": 5, "fontSize": 10, "fontWeight": "bold" },
          "transform": [{ "filter": "datum.year === 2019 && datum.Series === 'Inbound'" }],
          "encoding": {
            "x": { "field": "year", "type": "quantitative" },
            "y": { "field": "travellers", "type": "quantitative" },
            "color": { "field": "Series", "type": "nominal" },
            "text": { "value": "Inbound" }
          }
        },
        {
          "description": "Inline text labeling for Outbound trend line",
          "mark": { "type": "text", "align": "left", "dx": 8, "dy": 10, "fontSize": 10, "fontWeight": "bold" },
          "transform": [{ "filter": "datum.year === 2019 && datum.Series === 'Outbound'" }],
          "encoding": {
            "x": { "field": "year", "type": "quantitative" },
            "y": { "field": "travellers", "type": "quantitative" },
            "color": { "field": "Series", "type": "nominal" },
            "text": { "value": "Outbound" }
          }
        }
      ]
    },
    {
      "width": 700, "height": 160,
      "title": { "text": "International Spend in Australia ($B Real) — filtered by brush above", "fontSize": 12, "color": "#555" },
      "transform": [{ "filter": { "param": "brush" } }],
      "layer": [
        {
          "mark": { "type": "area", "opacity": 0.12, "color": "#009b9e", "interpolate": "monotone" },
          "encoding": {
            "x": { "field": "year", "type": "quantitative", "scale": { "zero": false }, "axis": { "format": "d", "title": "Year", "labelAngle": 0 } },
            "y": { "field": "intl_spend_real", "type": "quantitative", "axis": { "title": "Spend ($B Real)", "format": ".0f" }, "scale": { "zero": true } }
          }
        },
        {
          "mark": { "type": "line", "strokeWidth": 2.5, "color": "#009b9e", "interpolate": "monotone" },
          "transform": [{ "filter": "datum.type === 'actual'" }],
          "encoding": {
            "x": { "field": "year", "type": "quantitative" },
            "y": { "field": "intl_spend_real", "type": "quantitative" }
          }
        },
        {
          "mark": { "type": "line", "strokeWidth": 2.5, "color": "#009b9e", "strokeDash": [6,4], "interpolate": "monotone" },
          "transform": [{ "filter": "datum.type === 'forecast' || datum.year === 2024" }],
          "encoding": {
            "x": { "field": "year", "type": "quantitative" },
            "y": { "field": "intl_spend_real", "type": "quantitative" }
          }
        },
        {
          "mark": { "type": "circle", "size": 60, "color": "#009b9e", "opacity": 0.6 },
          "encoding": {
            "x": { "field": "year", "type": "quantitative" },
            "y": { "field": "intl_spend_real", "type": "quantitative" },
            "tooltip": [
              { "field": "year", "type": "quantitative", "title": "Year", "format": "d" },
              { "field": "intl_spend_real", "type": "quantitative", "title": "Spend Real ($B)", "format": ".2f" }
            ]
          }
        }
      ]
    }
  ],
  "config": { 
    "view": { "stroke": null }, 
    "axis": { "grid": true, "gridColor": "#f0f0f0" },
    "legend": { "orient": "top", "titleFontSize": 11, "labelFontSize": 11 }
  }
}
