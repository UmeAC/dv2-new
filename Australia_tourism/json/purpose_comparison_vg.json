{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "url": "https://raw.githubusercontent.com/UmeAC/dv2-new/refs/heads/main/Australia_tourism/data/international_by_purpose.csv",
    "format": { "type": "csv", "parse": { "year": "number", "arrivals": "number" } }
  },
  "params": [
    {
      "name": "purpose_sel",
      "select": { "type": "point", "fields": ["purpose"] },
      "bind": "legend"
    }
  ],
  "hconcat": [
    {
      "title": { "text": "International Arrivals by Purpose ('000)", "fontSize": 13, "color": "#333" },
      "width": 310,
      "height": 360,
      "transform": [
        { "filter": "datum.purpose !== 'Total' && datum.type === 'forecast'" }
      ],
      "mark": { "type": "area", "interpolate": "monotone" },
      "encoding": {
        "x": {
          "field": "year", "type": "quantitative",
          "axis": { "title": "Year", "format": "d", "labelAngle": 0 },
          "scale": { "zero": false, "domain": [2025, 2030] }
        },
        "y": {
          "field": "arrivals", "type": "quantitative",
          "stack": "zero",
          "axis": { "title": "Arrivals ('000)", "format": ",.0f" }
        },
        "color": {
          "field": "purpose", "type": "nominal", "title": "Purpose",
          "scale": {
            "domain": ["Holiday","VFR","Business","Education","Employment","Other"],
            "range": ["#005ab5","#dc7d28","#009b9e","#785ef0","#e0baaa","#777777"]
          }
        },
        "opacity": {
          "condition": { "param": "purpose_sel", "empty": true, "value": 0.85 },
          "value": 0.15
        },
        "tooltip": [
          { "field": "year", "type": "ordinal", "title": "Year" },
          { "field": "purpose", "type": "nominal", "title": "Purpose" },
          { "field": "arrivals", "type": "quantitative", "title": "Arrivals ('000)", "format": ",.1f" }
        ]
      }
    },
    {
      "title": { "text": "Domestic Overnight Trips by Purpose ('000)", "fontSize": 13, "color": "#333" },
      "width": 310,
      "height": 360,
      "data": {
        "url": "https://raw.githubusercontent.com/UmeAC/dv2-new/refs/heads/main/Australia_tourism/data/domestic_state_purpose.csv",
        "format": { 
          "type": "csv", 
          "parse": { "year": "number", "holiday": "number", "vfr": "number", "business": "number", "other": "number" } 
        }
      },
      "transform": [
        { "fold": ["holiday","vfr","business","other"], "as": ["purpose_raw","trips"] },
        { "calculate": "datum.purpose_raw === 'holiday' ? 'Holiday' : datum.purpose_raw === 'vfr' ? 'VFR' : datum.purpose_raw === 'business' ? 'Business' : 'Other'", "as": "purpose" },
        { "aggregate": [{ "op": "sum", "field": "trips", "as": "total_trips" }], "groupby": ["year","purpose"] }
      ],
      "mark": { "type": "area", "interpolate": "monotone" },
      "encoding": {
        "x": {
          "field": "year", "type": "quantitative",
          "axis": { "title": "Year", "format": "d", "labelAngle": 0 },
          "scale": { "zero": false, "domain": [2025, 2030] }
        },
        "y": {
          "field": "total_trips", "type": "quantitative",
          "stack": "zero",
          "axis": { "title": "Trips ('000)", "format": ",.0f" }
        },
        "color": {
          "field": "purpose", "type": "nominal", "title": "Purpose",
          "scale": {
            "domain": ["Holiday","VFR","Business","Other"],
            "range": ["#005ab5","#dc7d28","#009b9e","#777777"]
          }
        },
        "opacity": {
          "condition": { "param": "purpose_sel", "empty": true, "value": 0.85 },
          "value": 0.15
        },
        "tooltip": [
          { "field": "year", "type": "ordinal", "title": "Year" },
          { "field": "purpose", "type": "nominal", "title": "Purpose" },
          { "field": "total_trips", "type": "quantitative", "title": "Trips ('000)", "format": ",.0f" }
        ]
      }
    }
  ],
  "config": { "view": { "stroke": null }, "axis": { "grid": true, "gridColor": "#f0f0f0" } }
}
