{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "International Travel to Australia - Year Ending December 2025",
    "fontSize": 16,
    "fontWeight": "bold",
    "anchor": "start",
    "offset": 15
  },
  "params": [
    {
      "name": "region_select",
      "value": "All",
      "bind": {
        "input": "select",
        "name": "Region: ",
        "options": ["All", "Asia", "Europe", "Americas", "Oceania", "Other"]
      }
    },
    {
      "name": "top_n",
      "value": 10,
      "bind": {
        "input": "range",
        "min": 3,
        "max": 25,
        "step": 1,
        "name": "Show top N countries: "
      }
    }
  ],
  "hconcat": [
    {
      "title": "Top Countries by Trips",
      "height": 420,
      "width": 250,
      "data": {
        "url": "https://raw.githubusercontent.com/UmeAC/DV2/refs/heads/main/data/international_travel-2.csv",
        "format": {
          "type": "csv",
          "parse": {
            "trips_2025": "number",
            "spend_2025": "number",
            "nights_2025": "number",
            "trips_change_pct": "number"
          }
        }
      },
      "mark": {
        "type": "bar",
        "cornerRadiusTopRight": 3,
        "cornerRadiusBottomRight": 3
      },
      "transform": [
        { "filter": "datum.country !== 'Total'" },
        { "filter": "region_select === 'All' || datum.region === region_select" },
        { "window": [{ "op": "rank", "as": "trips_rank" }], "sort": [{ "field": "trips_2025", "order": "descending" }] },
        { "filter": "datum.trips_rank <= top_n" }
      ],
      "encoding": {
        "x": {
          "field": "trips_2025",
          "type": "quantitative",
          "title": "Trips ('000)",
          "axis": { "format": ",.0f" }
        },
        "y": {
          "field": "country",
          "type": "nominal",
          "sort": "-x",
          "title": null,
          "axis": { "labelFontSize": 10 }
        },
        "color": {
          "field": "region",
          "type": "nominal",
          "scale": {
            "domain": ["Asia", "Europe", "Americas", "Oceania", "Other"],
            "range": ["#005ab5", "#dc7d28", "#009b9e", "#785ef0", "#777777"]
          },
          "legend": null
        },
        "tooltip": [
          { "field": "country", "type": "nominal", "title": "Country" },
          { "field": "region", "type": "nominal", "title": "Region" },
          { "field": "trips_2025", "type": "quantitative", "title": "Trips ('000)", "format": ",.1f" },
          { "field": "trips_change_pct", "type": "quantitative", "title": "Trips Change (%)", "format": ".1f" },
          { "field": "spend_2025", "type": "quantitative", "title": "Spend ($M)", "format": ",.1f" },
          { "field": "nights_2025", "type": "quantitative", "title": "Nights ('000)", "format": ",.1f" }
        ]
      }
    },
    {
      "title": "Trips ('000) vs Spend ($M) — bubble size = nights",
      "height": 420,
      "width": 300,
      "data": {
        "url": "https://raw.githubusercontent.com/UmeAC/DV2/refs/heads/main/data/international_travel-2.csv",
        "format": {
          "type": "csv",
          "parse": {
            "trips_2025": "number",
            "spend_2025": "number",
            "nights_2025": "number",
            "trips_change_pct": "number",
            "spend_change_pct": "number"
          }
        }
      },
      "layer": [
        {
          "mark": { "type": "point", "filled": true },
          "transform": [
            { "filter": "datum.country !== 'Total'" },
            { "filter": "region_select === 'All' || datum.region === region_select" }
          ],
          "encoding": {
            "x": {
              "field": "trips_2025",
              "type": "quantitative",
              "title": "Trips ('000)",
              "axis": { "format": ",.0f" }
            },
            "y": {
              "field": "spend_2025",
              "type": "quantitative",
              "title": "Spend in Australia ($M)",
              "axis": { "format": ",.0f" }
            },
            "size": {
              "field": "nights_2025",
              "type": "quantitative",
              "title": "Nights ('000)",
              "scale": { "range": [50, 700] },
              "legend": {
                "orient": "right",
                "direction": "vertical",
                "title": "Nights ('000)",
                "titleFontSize": 11,
                "labelFontSize": 10
              }
            },
            "color": {
              "field": "region",
              "type": "nominal",
              "scale": {
                "domain": ["Asia", "Europe", "Americas", "Oceania", "Other"],
                "range": ["#005ab5", "#dc7d28", "#009b9e", "#785ef0", "#777777"]
              },
              "legend": {
                "orient": "right",
                "direction": "vertical",
                "title": "Region",
                "symbolSize": 100,
                "labelFontSize": 11
              }
            },
            "opacity": { "value": 0.85 },
            "tooltip": [
              { "field": "country", "type": "nominal", "title": "Country" },
              { "field": "region", "type": "nominal", "title": "Region" },
              { "field": "trips_2025", "type": "quantitative", "title": "Trips ('000)", "format": ",.1f" },
              { "field": "nights_2025", "type": "quantitative", "title": "Nights ('000)", "format": ",.1f" },
              { "field": "spend_2025", "type": "quantitative", "title": "Spend ($M)", "format": ",.1f" },
              { "field": "trips_change_pct", "type": "quantitative", "title": "Trips Change (%)", "format": ".1f" },
              { "field": "spend_change_pct", "type": "quantitative", "title": "Spend Change (%)", "format": ".1f" }
            ]
          }
        },
        {
          "mark": {
            "type": "text",
            "align": "left",
            "dx": 8,
            "dy": -4,
            "fontSize": 10,
            "fontWeight": "bold"
          },
          "transform": [
            { "filter": "datum.country !== 'Total'" },
            { "filter": "region_select === 'All' || datum.region === region_select" },
            { "window": [{ "op": "rank", "as": "trips_rank" }], "sort": [{ "field": "trips_2025", "order": "descending" }] },
            { "window": [{ "op": "rank", "as": "spend_rank" }], "sort": [{ "field": "spend_2025", "order": "descending" }] },
            { "filter": "datum.trips_rank === 1 || datum.spend_rank === 1" }
          ],
          "encoding": {
            "x": { "field": "trips_2025", "type": "quantitative" },
            "y": { "field": "spend_2025", "type": "quantitative" },
            "text": { "field": "country", "type": "nominal" },
            "color": {
              "field": "region",
              "type": "nominal",
              "scale": {
                "domain": ["Asia", "Europe", "Americas", "Oceania", "Other"],
                "range": ["#005ab5", "#dc7d28", "#009b9e", "#785ef0", "#777777"]
              }
            }
          }
        }
      ]
    }
  ],
  "config": {
    "view": { "stroke": null },
    "axis": { "labelFontSize": 11 }
  }
}